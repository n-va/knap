#!/bin/bash
# Knap CLI — manage the Knap vault from the terminal
#
# ◈ Cairn

set -e

# Resolve real path through symlinks to find the vault
SCRIPT_PATH="${BASH_SOURCE[0]}"
while [ -L "$SCRIPT_PATH" ]; do
    LINK_TARGET=$(readlink "$SCRIPT_PATH")
    if [[ "$LINK_TARGET" == /* ]]; then
        SCRIPT_PATH="$LINK_TARGET"
    else
        SCRIPT_PATH="$(dirname "$SCRIPT_PATH")/$LINK_TARGET"
    fi
done
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"

# The vault is the parent of the repo (install.sh puts the repo at INSTALL_DIR)
# But the script lives in the repo root, which IS the vault
VAULT_DIR="$SCRIPT_DIR"

# --- Helpers ---

msg() {
    if command -v gum &>/dev/null; then
        gum style --foreground 135 "$1"
    else
        echo "$1"
    fi
}

faint() {
    if command -v gum &>/dev/null; then
        gum style --faint "$1"
    else
        echo "$1"
    fi
}

success() {
    if command -v gum &>/dev/null; then
        gum style --foreground 82 "$1"
    else
        echo "$1"
    fi
}

warn() {
    if command -v gum &>/dev/null; then
        gum style --foreground 214 "$1"
    else
        echo "$1"
    fi
}

# --- Subcommands ---

cmd_project() {
    local name="$1"
    if [ -z "$name" ]; then
        echo "Usage: knap project <name>"
        echo ""
        echo "Scaffold a new project in the vault."
        echo "Name should be title case, e.g. 'My App'"
        exit 1
    fi

    local project_dir="$VAULT_DIR/Projects/$name"

    if [ -d "$project_dir" ]; then
        warn "Project '$name' already exists at $project_dir"
        exit 1
    fi

    mkdir -p "$project_dir"

    cat > "$project_dir/Changelog.md" << 'EOF'
Timestamped log of changes and updates.
EOF

    cat > "$project_dir/Todos.md" << 'EOF'
- [ ] Review project and add initial notes
EOF

    cat > "$project_dir/Notes.md" << 'EOF'
## Overview

(Add project overview here)
EOF

    cat > "$project_dir/Last Session.md" << 'EOF'
Updated automatically at the end of each Claude Code session.
EOF

    cat > "$project_dir/Context Map.md" << 'EOF'
When working on files matching these paths, read the linked doc for context.

| Path Pattern | Read |
|-------------|------|
EOF

    success "✓ Scaffolded project: $name"
    faint "  $project_dir/"
}

cmd_projects() {
    local projects_dir="$VAULT_DIR/Projects"
    if [ ! -d "$projects_dir" ]; then
        echo "No projects directory found."
        exit 1
    fi

    local count=0
    for dir in "$projects_dir"/*/; do
        [ -d "$dir" ] || continue
        local name=$(basename "$dir")
        local todos=$(grep -c '^\- \[ \]' "$dir/Todos.md" 2>/dev/null || true)
        local done=$(grep -c '^\- \[x\]' "$dir/Todos.md" 2>/dev/null || true)
        todos="${todos:-0}"
        done="${done:-0}"
        echo "  $name  ($todos open, $done done)"
        count=$((count + 1))
    done

    if [ $count -eq 0 ]; then
        faint "No projects yet. Create one with: knap project <name>"
    else
        echo ""
        faint "$count project(s)"
    fi
}

cmd_init() {
    local cwd="${1:-$(pwd)}"

    # Resolve project name from cwd
    local SEARCH_DIRS=("$HOME/Sites" "$HOME/Projects" "$HOME/Code" "$HOME/Developer" "$HOME/repos" "$HOME/src" "$HOME/workspace")
    local project_name=""
    local project_root=""
    for base in "${SEARCH_DIRS[@]}"; do
        if [[ "$cwd" == "$base/"* ]]; then
            local rel="${cwd#$base/}"
            local folder="${rel%%/*}"
            project_name=$(echo "$folder" | sed -E 's/(^|[-_])([a-z])/\U\2/g; s/[-_]/ /g')
            project_root="$base/$folder"
            break
        fi
    done

    # Fallback to git root
    if [ -z "$project_name" ]; then
        project_root=$(cd "$cwd" 2>/dev/null && git rev-parse --show-toplevel 2>/dev/null) || true
        if [ -z "$project_root" ]; then
            warn "Could not resolve project from $cwd"
            exit 1
        fi
        project_name=$(basename "$project_root" | sed -E 's/(^|[-_])([a-z])/\U\2/g; s/[-_]/ /g')
    fi

    local project_dir="$VAULT_DIR/Projects/$project_name"

    # Scaffold if it doesn't exist yet
    if [ ! -d "$project_dir" ]; then
        cmd_project "$project_name"
    fi

    msg "Initialising $project_name from $project_root..."
    echo ""

    # --- Notes.md: tech stack & structure ---
    local notes=""
    notes+="## Overview\n\n"

    # Detect tech stack
    local stack=()
    [ -f "$project_root/composer.json" ] && stack+=("PHP/Composer")
    [ -f "$project_root/package.json" ] && stack+=("Node/npm")
    [ -f "$project_root/Gemfile" ] && stack+=("Ruby/Bundler")
    [ -f "$project_root/go.mod" ] && stack+=("Go")
    [ -f "$project_root/Cargo.toml" ] && stack+=("Rust/Cargo")
    [ -f "$project_root/pyproject.toml" ] || [ -f "$project_root/requirements.txt" ] && stack+=("Python")
    [ -f "$project_root/Package.swift" ] && stack+=("Swift")

    # Detect frameworks
    if [ -f "$project_root/artisan" ]; then
        stack+=("Laravel")
        [ -f "$project_root/please" ] && stack+=("Statamic")
    fi
    if [ -f "$project_root/package.json" ]; then
        grep -q '"next"' "$project_root/package.json" 2>/dev/null && stack+=("Next.js")
        grep -q '"nuxt"' "$project_root/package.json" 2>/dev/null && stack+=("Nuxt")
        grep -q '"vue"' "$project_root/package.json" 2>/dev/null && stack+=("Vue")
        grep -q '"react"' "$project_root/package.json" 2>/dev/null && stack+=("React")
        grep -q '"svelte"' "$project_root/package.json" 2>/dev/null && stack+=("Svelte")
        grep -q '"@inertiajs' "$project_root/package.json" 2>/dev/null && stack+=("Inertia")
        grep -q '"tailwindcss"' "$project_root/package.json" 2>/dev/null && stack+=("Tailwind CSS")
    fi
    [ -f "$project_root/wp-config.php" ] || [ -f "$project_root/wp-content" ] && stack+=("WordPress")

    if [ ${#stack[@]} -gt 0 ]; then
        notes+="**Stack:** $(printf '%s\n' "${stack[@]}" | paste -sd', ' - | sed 's/,/, /g')\n\n"
    fi

    # Key directories
    notes+="## Structure\n\n"
    notes+='```\n'
    # List top-level dirs (excluding hidden, vendor, node_modules)
    for entry in "$project_root"/*/; do
        [ -d "$entry" ] || continue
        local dirname=$(basename "$entry")
        case "$dirname" in
            vendor|node_modules|.git|.idea|.vscode|storage|bootstrap|__pycache__) continue ;;
        esac
        notes+="$dirname/\n"
    done
    notes+='```\n'

    # Write Notes.md (only if still default placeholder)
    if grep -q "(Add project overview here)" "$project_dir/Notes.md" 2>/dev/null; then
        printf '%b' "$notes" > "$project_dir/Notes.md"
        faint "  ✓ Notes.md — stack & structure detected"
    else
        faint "  ⊘ Notes.md — already has content, skipped"
    fi

    # --- Changelog.md: seed from git log ---
    if [ -d "$project_root/.git" ]; then
        local changelog="$project_dir/Changelog.md"
        if ! grep -q "^## " "$changelog" 2>/dev/null; then
            local log_content=""
            log_content+="Timestamped log of changes and updates.\n\n"

            # Group recent commits by date (last 30)
            local current_date=""
            while IFS='|' read -r date msg; do
                [ -z "$date" ] && continue
                if [ "$date" != "$current_date" ]; then
                    current_date="$date"
                    log_content+="\n## $date\n\n"
                fi
                log_content+="- $msg\n"
            done < <(cd "$project_root" && git log --format='%as|%s' -30 2>/dev/null)

            if [ -n "$current_date" ]; then
                printf '%b' "$log_content" > "$changelog"
                faint "  ✓ Changelog.md — seeded from git history"
            fi
        else
            faint "  ⊘ Changelog.md — already has entries, skipped"
        fi
    fi

    # --- Todos.md: scan for TODO/FIXME comments ---
    local todo_file="$project_dir/Todos.md"
    if grep -q "Review project and add initial notes" "$todo_file" 2>/dev/null; then
        local todos=""
        local count=0

        # Search for TODO/FIXME in source files (limit to 20)
        while IFS=: read -r file line content; do
            [ -z "$content" ] && continue
            # Skip minified/long lines
            [ ${#content} -gt 200 ] && continue
            # Clean up the content
            local clean=$(echo "$content" | sed -E 's/^[[:space:]]*[\/\*#-]+ *//; s/[[:space:]]*\*\/$//' | head -c 120)
            local relfile="${file#$project_root/}"
            todos+="- [ ] $clean (\`$relfile:$line\`)\n"
            count=$((count + 1))
            [ $count -ge 20 ] && break
        done < <(cd "$project_root" && grep -rn 'TODO\|FIXME\|HACK\|XXX' \
            --include='*.php' --include='*.js' --include='*.ts' --include='*.vue' \
            --include='*.rb' --include='*.py' --include='*.go' --include='*.rs' \
            --include='*.swift' --include='*.blade.php' \
            --exclude-dir=vendor --exclude-dir=node_modules --exclude-dir=.git \
            --exclude-dir=storage --exclude-dir=bootstrap --exclude-dir=build \
            --exclude-dir=dist --exclude-dir=public/build --exclude-dir=.next \
            --exclude='*.min.js' --exclude='*.min.css' --exclude='*.map' \
            --exclude='*.lock' --exclude='*.chunk.*' 2>/dev/null || true)

        if [ $count -gt 0 ]; then
            printf '%b' "$todos" > "$todo_file"
            faint "  ✓ Todos.md — found $count TODO/FIXME comments"
        else
            echo "- [ ] Review project and add initial notes" > "$todo_file"
            faint "  ⊘ Todos.md — no TODOs found in source"
        fi
    else
        faint "  ⊘ Todos.md — already has content, skipped"
    fi

    # --- Context Map.md: detect docs & integrations ---
    local context_map="$project_dir/Context Map.md"
    if ! grep -q '|.*|.*|' "$context_map" 2>/dev/null || \
       [ "$(grep -c '|.*|.*|' "$context_map" 2>/dev/null)" -le 2 ]; then
        local map=""
        map+="When working on files matching these paths, read the linked doc for context.\n\n"
        map+="| Path Pattern | Read |\n"
        map+="|-------------|------|\n"

        # Detect docs directory
        if [ -d "$project_root/docs" ]; then
            for doc in "$project_root"/docs/*.md; do
                [ -f "$doc" ] || continue
                local docname=$(basename "$doc" .md)
                local slug=$(echo "$docname" | tr '[:upper:]' '[:lower:]' | sed 's/ /-/g')
                map+="| \`docs/$docname.md\` | Related integration docs |\n"
            done
        fi

        # Detect CLAUDE.md
        [ -f "$project_root/CLAUDE.md" ] && map+="| \`CLAUDE.md\` | Project-level AI instructions |\n"

        # Detect README
        [ -f "$project_root/README.md" ] && map+="| \`README.md\` | Project README |\n"

        printf '%b' "$map" > "$context_map"
        faint "  ✓ Context Map.md — mapped detected docs"
    else
        faint "  ⊘ Context Map.md — already has mappings, skipped"
    fi

    echo ""
    success "✓ $project_name initialised"
    faint "  $project_dir/"

    # --- Optional Claude analysis ---

    if ! command -v claude &>/dev/null; then
        faint "  Tip: install Claude Code to auto-generate richer Notes & Context Map"
        return
    fi

    echo ""
    if command -v gum &>/dev/null; then
        gum confirm "Let Claude analyse the project for richer Notes & Context Map?" || return
    else
        read -p "Let Claude analyse the project for richer Notes & Context Map? [y/N] " -n 1 -r
        echo ""
        [[ ! $REPLY =~ ^[Yy]$ ]] && return
    fi

    echo ""
    msg "Claude is analysing $project_name..."
    faint "  This may take a minute."
    echo ""

    local claude_prompt="You are initialising a Knap project vault for \"$project_name\".
The project source is at: $project_root
The vault files are at: $project_dir

Your job is to read the codebase and write two files. Be concise and useful -- these files are read by AI sessions to understand the project quickly.

1. Notes.md ($project_dir/Notes.md)

Write a project overview covering: what the project does (one paragraph), tech stack with versions where available, key directories and what they contain, important architectural decisions or patterns, any integrations with external services, and how to run the project locally (dev server, build commands). Keep it under 60 lines. Use markdown headers. No fluff.

2. Context Map.md ($project_dir/Context Map.md)

Build a markdown table mapping file path patterns to documentation or context that would help understand them. Format: | Path Pattern | Read | with backtick-wrapped paths. Look for API integrations and their docs (check docs/ folder, README, CLAUDE.md), complex subsystems that need explanation, config files that control important behaviour, and test directories and what they cover. Only include paths that genuinely need context -- do not map obvious things.

Write both files now using the Write tool. Overwrite whatever is there."

    if cd "$project_root" && CLAUDECODE= claude -p \
        --model sonnet \
        --allowedTools "Read Glob Grep Write" \
        --dangerously-skip-permissions \
        "$claude_prompt"; then
        echo ""
        success "✓ Claude analysis complete"
        faint "  Review: $project_dir/Notes.md"
        faint "  Review: $project_dir/Context Map.md"
    else
        echo ""
        warn "Claude analysis failed — bash-generated files are still in place"
    fi
}

cmd_populate() {
    if ! command -v gum &>/dev/null; then
        warn "gum is required for interactive selection. Install: brew install gum"
        exit 1
    fi

    local SEARCH_DIRS=("$HOME/Sites" "$HOME/Projects" "$HOME/Code" "$HOME/Developer" "$HOME/repos" "$HOME/src" "$HOME/workspace")
    local FOUND_DIRS=()
    for d in "${SEARCH_DIRS[@]}"; do
        [ -d "$d" ] && FOUND_DIRS+=("$d")
    done

    if [ ${#FOUND_DIRS[@]} -eq 0 ]; then
        warn "No project directories found."
        exit 1
    fi

    local PROJECTS=()
    for sites_dir in "${FOUND_DIRS[@]}"; do
        for dir in "$sites_dir"/*/; do
            [ -d "$dir" ] || continue
            local name=$(basename "$dir")
            [[ "$name" == .* ]] && continue
            local title=$(echo "$name" | sed -E 's/(^|[-_])([a-z])/\U\2/g; s/[-_]/ /g')
            [ -d "$VAULT_DIR/Projects/$title" ] && continue
            printf '%s\n' "${PROJECTS[@]}" | grep -qx "$title" 2>/dev/null && continue
            PROJECTS+=("$title")
        done
    done

    if [ ${#PROJECTS[@]} -eq 0 ]; then
        faint "All projects already scaffolded."
        return
    fi

    local DIRS_LABEL=$(printf '%s\n' "${FOUND_DIRS[@]}" | sed "s|$HOME|~|g" | paste -sd', ' - | sed 's/,/, /g')
    local SELECTED
    SELECTED=$(printf '%s\n' "${PROJECTS[@]}" | sort | gum choose --no-limit --header "Scaffold projects from $DIRS_LABEL:") || true

    if [ -z "$SELECTED" ]; then return; fi

    while IFS= read -r project; do
        [ -z "$project" ] && continue
        cmd_project "$project"
    done <<< "$SELECTED"
}

cmd_update() {
    local REMOTE_URL="https://raw.githubusercontent.com/n-va/knap/main"

    msg "Updating Knap..."
    echo ""

    # Download latest CLI
    local tmp_knap=$(mktemp)
    curl -fsSL "$REMOTE_URL/knap" -o "$tmp_knap" 2>/dev/null || {
        warn "Failed to download latest CLI"
        rm -f "$tmp_knap"
        exit 1
    }
    cp "$tmp_knap" "$VAULT_DIR/knap"
    chmod +x "$VAULT_DIR/knap"
    rm -f "$tmp_knap"
    faint "  ✓ CLI updated"

    # Download latest install.sh and run in update mode
    local tmp_installer=$(mktemp)
    curl -fsSL "$REMOTE_URL/install.sh" -o "$tmp_installer" 2>/dev/null || {
        warn "Failed to download latest installer"
        rm -f "$tmp_installer"
        exit 1
    }
    bash "$tmp_installer" --update --dir "$VAULT_DIR"
    rm -f "$tmp_installer"
}

cmd_sync() {
    if [ ! -d "$VAULT_DIR/.git" ]; then
        warn "Vault is not a git repository."
        exit 1
    fi

    cd "$VAULT_DIR"

    if git diff --quiet && git diff --cached --quiet && [ -z "$(git ls-files --others --exclude-standard)" ]; then
        faint "Nothing to sync — vault is clean."
        return
    fi

    git add -A
    CHANGED=$(git diff --cached --name-only)
    PARTS=()
    PROJECTS=$(echo "$CHANGED" | grep '^Projects/' | cut -d/ -f2 | sort -u | xargs 2>/dev/null)
    echo "$CHANGED" | grep -q '^skills/' && PARTS+=("skills")
    echo "$CHANGED" | grep -q '^HEART\.md' && PARTS+=("HEART")
    echo "$CHANGED" | grep -q '^PULSE\.md' && PARTS+=("PULSE")
    for p in $PROJECTS; do PARTS+=("$p"); done
    MSG=$(printf '%s\n' "${PARTS[@]}" | awk '!seen[$0]++' | paste -sd',' - | sed 's/,/, /g')
    if [ -z "$MSG" ]; then MSG="auto-sync $(date +%Y-%m-%d_%H:%M)"; fi

    git commit -m "docs: update ${MSG}" --quiet 2>/dev/null || true
    git push --quiet 2>/dev/null || true
    success "✓ Vault synced"
}

cmd_status() {
    local projects_dir="$VAULT_DIR/Projects"
    local count=0
    if [ -d "$projects_dir" ]; then
        for dir in "$projects_dir"/*/; do
            [ -d "$dir" ] || continue
            count=$((count + 1))
        done
    fi

    msg "Knap vault: $VAULT_DIR"
    echo "  Projects: $count"

    if [ -d "$VAULT_DIR/.git" ]; then
        cd "$VAULT_DIR"
        local dirty=$(git status --porcelain 2>/dev/null | wc -l | tr -d ' ')
        if [ "$dirty" -gt 0 ]; then
            warn "  Uncommitted changes: $dirty file(s)"
        else
            faint "  Git: clean"
        fi
        local remote=$(git remote get-url origin 2>/dev/null || echo "none")
        faint "  Remote: $remote"
    fi
}

cmd_help() {
    echo ""
    msg "knap — manage the Knap vault"
    echo ""
    echo "  knap init             Auto-populate project from cwd (stack, git log, TODOs)"
    echo "  knap project <name>   Scaffold a new project"
    echo "  knap populate         Scan local dirs and scaffold new projects"
    echo "  knap projects         List all projects"
    echo "  knap sync             Commit & push vault changes"
    echo "  knap update           Pull latest hooks, skills & CLI from GitHub"
    echo "  knap status           Show vault info"
    echo "  knap help             Show this help"
    echo ""
}

# --- Dispatch ---

case "${1:-}" in
    init)     cmd_init ;;
    project)  cmd_project "$2" ;;
    populate) cmd_populate ;;
    projects) cmd_projects ;;
    sync)     cmd_sync ;;
    update)   cmd_update ;;
    status)   cmd_status ;;
    help)     cmd_help ;;
    *)        cmd_help ;;
esac
