#!/bin/bash
# Knap CLI — manage the Knap vault from the terminal
#
# github.com/n-va/knap

KNAP_VERSION="1.3.0"

set -e

# Resolve real path through symlinks to find the vault
SCRIPT_PATH="${BASH_SOURCE[0]}"
while [ -L "$SCRIPT_PATH" ]; do
    LINK_TARGET=$(readlink "$SCRIPT_PATH")
    if [[ "$LINK_TARGET" == /* ]]; then
        SCRIPT_PATH="$LINK_TARGET"
    else
        SCRIPT_PATH="$(dirname "$SCRIPT_PATH")/$LINK_TARGET"
    fi
done
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"

# The vault is the parent of the repo (install.sh puts the repo at INSTALL_DIR)
# But the script lives in the repo root, which IS the vault
VAULT_DIR="$SCRIPT_DIR"

# --- Helpers ---

msg() {
    if command -v gum &>/dev/null; then
        gum style --foreground 135 "$1"
    else
        echo "$1"
    fi
}

faint() {
    if command -v gum &>/dev/null; then
        gum style --faint "$1"
    else
        echo "$1"
    fi
}

success() {
    if command -v gum &>/dev/null; then
        gum style --foreground 82 "$1"
    else
        echo "$1"
    fi
}

warn() {
    if command -v gum &>/dev/null; then
        gum style --foreground 214 "$1"
    else
        echo "$1"
    fi
}

# --- Subcommands ---

cmd_project() {
    local name="$1"
    if [ -z "$name" ]; then
        echo "Usage: knap project <name>"
        echo ""
        echo "Scaffold a new project in the vault."
        echo "Name should be title case, e.g. 'My App'"
        exit 1
    fi

    local project_dir="$VAULT_DIR/Projects/$name"

    if [ -d "$project_dir" ]; then
        warn "Project '$name' already exists at $project_dir"
        exit 1
    fi

    mkdir -p "$project_dir"

    local today=$(date +%Y-%m-%d)

    cat > "$project_dir/context.md" << EOF
# $name

## Overview
(What this project is, one paragraph)

## Stack
(Framework, language, versions, hosting)

## Key Files
(Important file paths and what they do)

## Decisions
(Important decisions and WHY they were made)

## Gotchas
(Things that will trip you up)
EOF

    cat > "$project_dir/plan.md" << 'EOF'
# Plan

## Now
- [ ] Review project and add initial notes

## Next

## Later

## Done
EOF

    cat > "$project_dir/log.md" << EOF
# Log

## $today
- Project scaffolded
EOF

    success "✓ Scaffolded project: $name"
    faint "  $project_dir/"
    faint "  Files: context.md, plan.md, log.md"
}

cmd_projects() {
    local projects_dir="$VAULT_DIR/Projects"
    if [ ! -d "$projects_dir" ]; then
        echo "No projects directory found."
        exit 1
    fi

    local count=0
    for dir in "$projects_dir"/*/; do
        [ -d "$dir" ] || continue
        local name=$(basename "$dir")
        # Support both old (Todos.md) and new (plan.md) conventions
        local plan_file="$dir/plan.md"
        [ ! -f "$plan_file" ] && plan_file="$dir/Todos.md"
        local todos=$(grep -c '^\- \[ \]' "$plan_file" 2>/dev/null || true)
        local done=$(grep -c '^\- \[x\]' "$plan_file" 2>/dev/null || true)
        todos="${todos:-0}"
        done="${done:-0}"
        echo "  $name  ($todos open, $done done)"
        count=$((count + 1))
    done

    if [ $count -eq 0 ]; then
        faint "No projects yet. Create one with: knap project <name>"
    else
        echo ""
        faint "$count project(s)"
    fi
}

cmd_init() {
    local cwd="${1:-$(pwd)}"

    # Resolve project name from cwd
    local SEARCH_DIRS=("$HOME/Sites" "$HOME/Projects" "$HOME/Code" "$HOME/Developer" "$HOME/repos" "$HOME/src" "$HOME/workspace")
    local project_name=""
    local project_root=""
    for base in "${SEARCH_DIRS[@]}"; do
        if [[ "$cwd" == "$base/"* ]]; then
            local rel="${cwd#$base/}"
            local folder="${rel%%/*}"
            project_name=$(echo "$folder" | sed -E 's/(^|[-_])([a-z])/\U\2/g; s/[-_]/ /g')
            project_root="$base/$folder"
            break
        fi
    done

    # Fallback to git root
    if [ -z "$project_name" ]; then
        project_root=$(cd "$cwd" 2>/dev/null && git rev-parse --show-toplevel 2>/dev/null) || true
        if [ -z "$project_root" ]; then
            warn "Could not resolve project from $cwd"
            exit 1
        fi
        project_name=$(basename "$project_root" | sed -E 's/(^|[-_])([a-z])/\U\2/g; s/[-_]/ /g')
    fi

    local project_dir="$VAULT_DIR/Projects/$project_name"

    # Scaffold if it doesn't exist yet
    if [ ! -d "$project_dir" ]; then
        cmd_project "$project_name"
    fi

    msg "Initialising $project_name from $project_root..."
    echo ""

    # --- Notes.md: tech stack & structure ---
    local notes=""
    notes+="## Overview\n\n"

    # Detect tech stack
    local stack=()
    [ -f "$project_root/composer.json" ] && stack+=("PHP/Composer")
    [ -f "$project_root/package.json" ] && stack+=("Node/npm")
    [ -f "$project_root/Gemfile" ] && stack+=("Ruby/Bundler")
    [ -f "$project_root/go.mod" ] && stack+=("Go")
    [ -f "$project_root/Cargo.toml" ] && stack+=("Rust/Cargo")
    [ -f "$project_root/pyproject.toml" ] || [ -f "$project_root/requirements.txt" ] && stack+=("Python")
    [ -f "$project_root/Package.swift" ] && stack+=("Swift")

    # Detect frameworks
    if [ -f "$project_root/artisan" ]; then
        stack+=("Laravel")
        [ -f "$project_root/please" ] && stack+=("Statamic")
    fi
    if [ -f "$project_root/package.json" ]; then
        grep -q '"next"' "$project_root/package.json" 2>/dev/null && stack+=("Next.js")
        grep -q '"nuxt"' "$project_root/package.json" 2>/dev/null && stack+=("Nuxt")
        grep -q '"vue"' "$project_root/package.json" 2>/dev/null && stack+=("Vue")
        grep -q '"react"' "$project_root/package.json" 2>/dev/null && stack+=("React")
        grep -q '"svelte"' "$project_root/package.json" 2>/dev/null && stack+=("Svelte")
        grep -q '"@inertiajs' "$project_root/package.json" 2>/dev/null && stack+=("Inertia")
        grep -q '"tailwindcss"' "$project_root/package.json" 2>/dev/null && stack+=("Tailwind CSS")
    fi
    [ -f "$project_root/wp-config.php" ] || [ -f "$project_root/wp-content" ] && stack+=("WordPress")

    if [ ${#stack[@]} -gt 0 ]; then
        notes+="**Stack:** $(printf '%s\n' "${stack[@]}" | paste -sd', ' - | sed 's/,/, /g')\n\n"
    fi

    # Key directories
    notes+="## Structure\n\n"
    notes+='```\n'
    # List top-level dirs (excluding hidden, vendor, node_modules)
    for entry in "$project_root"/*/; do
        [ -d "$entry" ] || continue
        local dirname=$(basename "$entry")
        case "$dirname" in
            vendor|node_modules|.git|.idea|.vscode|storage|bootstrap|__pycache__) continue ;;
        esac
        notes+="$dirname/\n"
    done
    notes+='```\n'

    # Enrich context.md with detected stack & structure
    local context_file="$project_dir/context.md"
    if grep -q "(What this project is" "$context_file" 2>/dev/null; then
        # Still has placeholder — replace the Overview and Stack sections
        local tmp=$(mktemp)
        local in_overview=false
        local in_stack=false
        local wrote_overview=false
        local wrote_stack=false
        while IFS= read -r line; do
            if [[ "$line" == "## Overview"* ]]; then
                echo "$line" >> "$tmp"
                printf '%b' "$notes" >> "$tmp"
                in_overview=true
                wrote_overview=true
                continue
            fi
            if [[ "$line" == "## Stack"* ]]; then
                echo "$line" >> "$tmp"
                if [ ${#stack[@]} -gt 0 ]; then
                    echo "$(printf '%s\n' "${stack[@]}" | paste -sd', ' - | sed 's/,/, /g')" >> "$tmp"
                fi
                in_stack=true
                wrote_stack=true
                continue
            fi
            if [[ "$line" == "## "* ]]; then
                in_overview=false
                in_stack=false
            fi
            if [ "$in_overview" = true ] || [ "$in_stack" = true ]; then
                continue  # skip placeholder content
            fi
            echo "$line" >> "$tmp"
        done < "$context_file"
        mv "$tmp" "$context_file"
        faint "  ✓ context.md — stack & structure detected"
    else
        faint "  ⊘ context.md — already has content, skipped"
    fi

    # --- log.md: seed from git log ---
    if [ -d "$project_root/.git" ]; then
        local log_file="$project_dir/log.md"
        # Only seed if log.md just has the scaffold entry
        if grep -q "^- Project scaffolded$" "$log_file" 2>/dev/null; then
            local log_content=""
            log_content+="# Log\n\n"

            local current_date=""
            while IFS='|' read -r date msg; do
                [ -z "$date" ] && continue
                if [ "$date" != "$current_date" ]; then
                    current_date="$date"
                    log_content+="\n## $date\n"
                fi
                log_content+="- $msg\n"
            done < <(cd "$project_root" && git log --format='%as|%s' -30 2>/dev/null)

            if [ -n "$current_date" ]; then
                printf '%b' "$log_content" > "$log_file"
                faint "  ✓ log.md — seeded from git history"
            fi
        else
            faint "  ⊘ log.md — already has entries, skipped"
        fi
    fi

    # --- plan.md: scan for TODO/FIXME comments ---
    local plan_file="$project_dir/plan.md"
    if grep -q "Review project and add initial notes" "$plan_file" 2>/dev/null; then
        local todos=""
        local count=0

        while IFS=: read -r file line content; do
            [ -z "$content" ] && continue
            [ ${#content} -gt 200 ] && continue
            local clean=$(echo "$content" | sed -E 's/^[[:space:]]*[\/\*#-]+ *//; s/[[:space:]]*\*\/$//' | head -c 120)
            local relfile="${file#$project_root/}"
            todos+="- [ ] $clean (\`$relfile:$line\`)\n"
            count=$((count + 1))
            [ $count -ge 20 ] && break
        done < <(cd "$project_root" && grep -rn 'TODO\|FIXME\|HACK\|XXX' \
            --include='*.php' --include='*.js' --include='*.ts' --include='*.vue' \
            --include='*.rb' --include='*.py' --include='*.go' --include='*.rs' \
            --include='*.swift' --include='*.blade.php' \
            --exclude-dir=vendor --exclude-dir=node_modules --exclude-dir=.git \
            --exclude-dir=storage --exclude-dir=bootstrap --exclude-dir=build \
            --exclude-dir=dist --exclude-dir=public/build --exclude-dir=.next \
            --exclude='*.min.js' --exclude='*.min.css' --exclude='*.map' \
            --exclude='*.lock' --exclude='*.chunk.*' 2>/dev/null || true)

        if [ $count -gt 0 ]; then
            # Replace the placeholder todo with found TODOs
            local tmp=$(mktemp)
            local replaced=false
            while IFS= read -r line; do
                if [ "$replaced" = false ] && [[ "$line" == *"Review project and add initial notes"* ]]; then
                    printf '%b' "$todos" >> "$tmp"
                    replaced=true
                else
                    echo "$line" >> "$tmp"
                fi
            done < "$plan_file"
            mv "$tmp" "$plan_file"
            faint "  ✓ plan.md — found $count TODO/FIXME comments"
        else
            faint "  ⊘ plan.md — no TODOs found in source"
        fi
    else
        faint "  ⊘ plan.md — already has content, skipped"
    fi

    # --- Copy project skills to vault ---
    local skills_copied=0
    local vault_skills="$VAULT_DIR/skills"
    for skills_dir in "$project_root/.claude/skills" "$project_root/.github/skills"; do
        [ -d "$skills_dir" ] || continue
        for skill in "$skills_dir"/*/; do
            [ -d "$skill" ] || continue
            local skill_name=$(basename "$skill")
            if [ -d "$vault_skills/$skill_name" ]; then
                continue
            fi
            cp -r "$skill" "$vault_skills/$skill_name"
            skills_copied=$((skills_copied + 1))
            faint "  ✓ Skill copied: $skill_name"
        done
    done
    if [ $skills_copied -eq 0 ]; then
        faint "  ⊘ No new skills to copy"
    fi

    echo ""
    success "✓ $project_name initialised"
    faint "  $project_dir/"

    # --- Optional AI analysis ---

    # Read tool preference from config
    local ai_tool="claude"
    local config_file="$VAULT_DIR/.knap-config"
    if [ -f "$config_file" ]; then
        ai_tool=$(grep '^ai_tool=' "$config_file" 2>/dev/null | cut -d= -f2 || echo "claude")
    fi
    ai_tool="${ai_tool:-claude}"

    # Resolve the AI binary
    local ai_bin=""
    local ai_label=""
    if [ "$ai_tool" = "codex" ] || [ "$ai_tool" = "both" ]; then
        ai_bin=$(command -v codex 2>/dev/null || true)
        [ -n "$ai_bin" ] && ai_label="Codex"
    fi
    if [ -z "$ai_bin" ] && { [ "$ai_tool" = "claude" ] || [ "$ai_tool" = "both" ]; }; then
        ai_bin=$(command -v claude 2>/dev/null || echo "$HOME/.local/bin/claude")
        [ -x "$ai_bin" ] && ai_label="Claude" || ai_bin=""
    fi

    if [ -z "$ai_bin" ]; then
        faint "  Tip: install Claude Code or Codex to auto-generate richer context.md"
        return
    fi

    echo ""
    if command -v gum &>/dev/null; then
        gum confirm "Let $ai_label analyse the project for a richer context.md?" || return
    else
        read -p "Let $ai_label analyse the project for a richer context.md? [y/N] " -n 1 -r
        echo ""
        [[ ! $REPLY =~ ^[Yy]$ ]] && return
    fi

    echo ""
    msg "$ai_label is analysing $project_name..."
    faint "  This may take a minute."
    echo ""

    local analysis_prompt="You are initialising a Knap project vault for \"$project_name\".
The project source is at: $project_root
The vault file is at: $project_dir/context.md

Read the codebase and rewrite context.md. Be concise and useful -- this file is read by AI sessions to understand the project quickly.

Use this structure (keep the exact headers):

# $project_name

## Overview
What the project does (one paragraph).

## Stack
Framework, language, versions, hosting, how to run locally.

## Key Files
Important file paths and what they do. Focus on non-obvious ones.

## Decisions
Architectural decisions and patterns worth knowing. Only include things that would surprise someone new to the codebase.

## Gotchas
Things that will trip you up. Real gotchas from the code, not generic advice.

Keep it under 80 lines total. No fluff. Write the file now."

    cd "$project_root"

    # Build the command based on the tool
    local tmp_output=$(mktemp)
    if [ "$ai_label" = "Codex" ]; then
        "$ai_bin" exec \
            --full-auto \
            --quiet \
            "$analysis_prompt" > "$tmp_output" 2>&1 &
    else
        CLAUDECODE= "$ai_bin" -p \
            --model sonnet \
            --allowedTools "Read Glob Grep Write" \
            --dangerously-skip-permissions \
            "$analysis_prompt" > "$tmp_output" 2>&1 &
    fi
    local ai_pid=$!

    # Spinner in foreground — Ctrl+C kills everything
    local spinner_chars='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
    trap 'kill $ai_pid 2>/dev/null; wait $ai_pid 2>/dev/null; printf "\r\033[K"; rm -f "$tmp_output"; echo ""; faint "Cancelled."; trap - INT EXIT; exit 130' INT
    trap 'kill $ai_pid 2>/dev/null; printf "\r\033[K"; rm -f "$tmp_output"' EXIT

    local i=0
    while kill -0 $ai_pid 2>/dev/null; do
        printf "\r  %s $ai_label is reading the codebase..." "${spinner_chars:$i:1}"
        i=$(( (i + 1) % ${#spinner_chars} ))
        sleep 0.1
    done
    printf "\r\033[K"

    wait $ai_pid
    local ai_exit=$?

    trap - INT EXIT

    if [ $ai_exit -eq 0 ]; then
        cat "$tmp_output"
        rm -f "$tmp_output"
        echo ""
        success "✓ $ai_label analysis complete"
        faint "  Review: $project_dir/context.md"
    else
        rm -f "$tmp_output"
        echo ""
        warn "$ai_label analysis failed — bash-generated files are still in place"
    fi
}

cmd_populate() {
    if ! command -v gum &>/dev/null; then
        warn "gum is required for interactive selection. Install: brew install gum"
        exit 1
    fi

    local SEARCH_DIRS=("$HOME/Sites" "$HOME/Projects" "$HOME/Code" "$HOME/Developer" "$HOME/repos" "$HOME/src" "$HOME/workspace")
    local FOUND_DIRS=()
    for d in "${SEARCH_DIRS[@]}"; do
        [ -d "$d" ] && FOUND_DIRS+=("$d")
    done

    if [ ${#FOUND_DIRS[@]} -eq 0 ]; then
        warn "No project directories found."
        exit 1
    fi

    local PROJECTS=()
    for sites_dir in "${FOUND_DIRS[@]}"; do
        for dir in "$sites_dir"/*/; do
            [ -d "$dir" ] || continue
            local name=$(basename "$dir")
            [[ "$name" == .* ]] && continue
            local title=$(echo "$name" | sed -E 's/(^|[-_])([a-z])/\U\2/g; s/[-_]/ /g')
            [ -d "$VAULT_DIR/Projects/$title" ] && continue
            printf '%s\n' "${PROJECTS[@]}" | grep -qx "$title" 2>/dev/null && continue
            PROJECTS+=("$title")
        done
    done

    if [ ${#PROJECTS[@]} -eq 0 ]; then
        faint "All projects already scaffolded."
        return
    fi

    local DIRS_LABEL=$(printf '%s\n' "${FOUND_DIRS[@]}" | sed "s|$HOME|~|g" | paste -sd', ' - | sed 's/,/, /g')
    local SELECTED
    SELECTED=$(printf '%s\n' "${PROJECTS[@]}" | sort | gum choose --no-limit --header "Scaffold projects from $DIRS_LABEL:") || true

    if [ -z "$SELECTED" ]; then return; fi

    while IFS= read -r project; do
        [ -z "$project" ] && continue
        cmd_project "$project"
    done <<< "$SELECTED"
}

cmd_update() {
    local REMOTE_URL="https://raw.githubusercontent.com/n-va/knap/main"

    msg "Updating Knap..."
    echo ""

    # Download latest CLI
    local tmp_knap=$(mktemp)
    curl -fsSL "$REMOTE_URL/knap" -o "$tmp_knap" 2>/dev/null || {
        warn "Failed to download latest CLI"
        rm -f "$tmp_knap"
        exit 1
    }

    # Check if there's actually an update
    local new_version
    new_version=$(grep '^KNAP_VERSION=' "$tmp_knap" 2>/dev/null | cut -d'"' -f2)
    local current_version="$KNAP_VERSION"

    if [ "$new_version" = "$current_version" ]; then
        faint "  Already on latest (v${current_version})"
        rm -f "$tmp_knap"
    else
        cp "$tmp_knap" "$VAULT_DIR/knap"
        chmod +x "$VAULT_DIR/knap"
        rm -f "$tmp_knap"
        success "  ✓ CLI updated: v${current_version} → v${new_version}"
    fi

    # Download latest install.sh and run in update mode
    local tmp_installer=$(mktemp)
    curl -fsSL "$REMOTE_URL/install.sh" -o "$tmp_installer" 2>/dev/null || {
        warn "Failed to download latest installer"
        rm -f "$tmp_installer"
        exit 1
    }
    bash "$tmp_installer" --update --dir "$VAULT_DIR"
    rm -f "$tmp_installer"
}

cmd_sync() {
    if [ ! -d "$VAULT_DIR/.git" ]; then
        warn "Vault is not a git repository."
        exit 1
    fi

    cd "$VAULT_DIR"

    # Pull remote changes first to avoid divergence
    git pull --rebase --quiet 2>/dev/null || true

    if git diff --quiet && git diff --cached --quiet && [ -z "$(git ls-files --others --exclude-standard)" ]; then
        faint "Nothing to sync — vault is clean."
        return
    fi

    git add -A
    CHANGED=$(git diff --cached --name-only)
    PARTS=()
    PROJECTS=$(echo "$CHANGED" | grep '^Projects/' | cut -d/ -f2 | sort -u | xargs 2>/dev/null)
    echo "$CHANGED" | grep -q '^skills/' && PARTS+=("skills")
    echo "$CHANGED" | grep -q '^HEART\.md' && PARTS+=("HEART")
    echo "$CHANGED" | grep -q '^RECENT\.md' && PARTS+=("RECENT")
    for p in $PROJECTS; do PARTS+=("$p"); done
    MSG=$(printf '%s\n' "${PARTS[@]}" | awk '!seen[$0]++' | paste -sd',' - | sed 's/,/, /g')
    if [ -z "$MSG" ]; then MSG="auto-sync $(date +%Y-%m-%d_%H:%M)"; fi

    git commit -m "docs: update ${MSG}" --quiet 2>/dev/null || true
    git push --quiet 2>/dev/null || true
    success "✓ Vault synced"
}

cmd_status() {
    local projects_dir="$VAULT_DIR/Projects"
    local count=0
    if [ -d "$projects_dir" ]; then
        for dir in "$projects_dir"/*/; do
            [ -d "$dir" ] || continue
            count=$((count + 1))
        done
    fi

    msg "Knap vault: $VAULT_DIR"
    echo "  Projects: $count"

    # Hook status
    local settings_file="$HOME/.claude/settings.json"
    if [ -f "$settings_file" ]; then
        local has_hooks
        has_hooks=$(jq -r '.hooks.UserPromptSubmit // [] | map(select(.hooks[]?.command | strings | test("knap"))) | length' "$settings_file" 2>/dev/null || echo "0")
        if [ "$has_hooks" -gt 0 ]; then
            success "  Hooks: enabled"
        else
            warn "  Hooks: disabled (run 'knap enable' to re-enable)"
        fi
    fi

    # Conventions status
    local claude_md="$HOME/.claude/CLAUDE.md"
    if [ -f "$claude_md" ]; then
        if grep -q "# Knap Conventions" "$claude_md" 2>/dev/null; then
            success "  CLAUDE.md: conventions active"
        else
            warn "  CLAUDE.md: conventions removed"
        fi
    fi

    if [ -d "$VAULT_DIR/.git" ]; then
        cd "$VAULT_DIR"
        local dirty=$(git status --porcelain 2>/dev/null | wc -l | tr -d ' ')
        if [ "$dirty" -gt 0 ]; then
            warn "  Uncommitted changes: $dirty file(s)"
        else
            faint "  Git: clean"
        fi
        local remote=$(git remote get-url origin 2>/dev/null || echo "none")
        faint "  Remote: $remote"
    fi
}

cmd_tidy() {
    local explicit_project=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -p)  shift; explicit_project="$1"; shift ;;
            --all) explicit_project="__all__"; shift ;;
            *)   shift ;;
        esac
    done

    local projects_dir="$VAULT_DIR/Projects"

    if [ "$explicit_project" = "__all__" ]; then
        local count=0
        for dir in "$projects_dir"/*/; do
            [ -d "$dir" ] || continue
            local name=$(basename "$dir")
            [ "$name" = "Archive" ] && continue
            tidy_project "$dir" "$name"
            count=$((count + 1))
        done
        # Also tidy archived projects
        if [ -d "$projects_dir/Archive" ]; then
            for dir in "$projects_dir/Archive"/*/; do
                [ -d "$dir" ] || continue
                local name=$(basename "$dir")
                tidy_project "$dir" "$name"
                count=$((count + 1))
            done
        fi
        echo ""
        success "✓ Tidied $count project(s)"
    else
        resolve_project "$explicit_project" || return
        tidy_project "$RESOLVED_PROJECT_DIR" "$RESOLVED_PROJECT_NAME"
    fi
}

tidy_project() {
    local dir="$1"
    local name="$2"
    local changes=0

    # Rename uppercase to lowercase
    for old_name in "CONTEXT.md" "PLAN.md" "LOG.md" "STATUS.md"; do
        local new_name=$(echo "$old_name" | tr '[:upper:]' '[:lower:]')
        if [ -f "$dir/$old_name" ] && [ "$old_name" != "$new_name" ]; then
            mv "$dir/$old_name" "$dir/$new_name"
            faint "  ✓ $name: $old_name → $new_name"
            changes=$((changes + 1))
        fi
    done

    # Absorb STATUS.md / status.md into context.md if both exist
    if [ -f "$dir/status.md" ] && [ -f "$dir/context.md" ]; then
        # Append useful STATUS content to context.md
        local status_content=$(cat "$dir/status.md")
        if echo "$status_content" | grep -q "^## Known Issues"; then
            local issues
            issues=$(sed -n '/^## Known Issues/,/^## /{ /^## /d; p; }' "$dir/status.md" 2>/dev/null | grep -v '^(')
            if [ -n "$issues" ]; then
                echo "" >> "$dir/context.md"
                echo "## Known Issues (from status.md)" >> "$dir/context.md"
                echo "$issues" >> "$dir/context.md"
            fi
        fi
        mv "$dir/status.md" "$dir/status.old.md"
        faint "  ✓ $name: status.md absorbed into context.md"
        changes=$((changes + 1))
    elif [ -f "$dir/status.md" ] && [ ! -f "$dir/context.md" ]; then
        mv "$dir/status.md" "$dir/context.md"
        faint "  ✓ $name: status.md → context.md"
        changes=$((changes + 1))
    fi

    # Rename old-format files (bash 3.2 compatible — no associative arrays)
    local old_files="Notes.md:context.md Todos.md:plan.md Changelog.md:log.md"
    for pair in $old_files; do
        local old_name="${pair%%:*}"
        local new_name="${pair##*:}"
        if [ -f "$dir/$old_name" ] && [ ! -f "$dir/$new_name" ]; then
            mv "$dir/$old_name" "$dir/$new_name"
            faint "  ✓ $name: $old_name → $new_name"
            changes=$((changes + 1))
        elif [ -f "$dir/$old_name" ] && [ -f "$dir/$new_name" ]; then
            mv "$dir/$old_name" "$dir/${old_name%.md}.old.md"
            faint "  ✓ $name: $old_name → ${old_name%.md}.old.md (kept $new_name)"
            changes=$((changes + 1))
        fi
    done
    # Handle space-in-name files separately
    for pair in "Context Map.md:context.md" "Last Session.md:log.md"; do
        local old_name="${pair%%:*}"
        local new_name="${pair##*:}"
        if [ -f "$dir/$old_name" ] && [ ! -f "$dir/$new_name" ]; then
            mv "$dir/$old_name" "$dir/$new_name"
            faint "  ✓ $name: $old_name → $new_name"
            changes=$((changes + 1))
        elif [ -f "$dir/$old_name" ] && [ -f "$dir/$new_name" ]; then
            local old_base="${old_name%.md}"
            mv "$dir/$old_name" "$dir/${old_base}.old.md"
            faint "  ✓ $name: $old_name → ${old_base}.old.md (kept $new_name)"
            changes=$((changes + 1))
        fi
    done

    # Ensure all three files exist
    local today=$(date +%Y-%m-%d)

    if [ ! -f "$dir/context.md" ]; then
        cat > "$dir/context.md" << EOF
# $name

## Overview
(What this project is, one paragraph)

## Stack
(Framework, language, versions, hosting)

## Key Files
(Important file paths and what they do)

## Decisions

## Gotchas
EOF
        faint "  ✓ $name: created context.md"
        changes=$((changes + 1))
    fi

    if [ ! -f "$dir/plan.md" ]; then
        cat > "$dir/plan.md" << 'EOF'
# Plan

## Now

## Next

## Later

## Done
EOF
        faint "  ✓ $name: created plan.md"
        changes=$((changes + 1))
    fi

    if [ ! -f "$dir/log.md" ]; then
        cat > "$dir/log.md" << EOF
# Log

## $today
- Project tidied
EOF
        faint "  ✓ $name: created log.md"
        changes=$((changes + 1))
    fi

    if [ $changes -eq 0 ]; then
        faint "  ⊘ $name — already tidy"
    else
        success "  ✓ $name — $changes change(s)"
    fi
}

cmd_migrate() {
    local project_name="$1"
    local projects_dir="$VAULT_DIR/Projects"

    if [ -n "$project_name" ]; then
        # Migrate a single project
        local dir="$projects_dir/$project_name"
        if [ ! -d "$dir" ]; then
            warn "Project '$project_name' not found"
            exit 1
        fi
        migrate_project "$dir" "$project_name"
    else
        # Migrate all projects
        for dir in "$projects_dir"/*/; do
            [ -d "$dir" ] || continue
            local name=$(basename "$dir")
            migrate_project "$dir" "$name"
        done
    fi

    success "✓ Migration complete"
    faint "  Old files preserved as *.old.md — delete when satisfied"
}

migrate_project() {
    local dir="$1"
    local name="$2"
    local today=$(date +%Y-%m-%d)

    # Skip if already migrated (has context.md with Overview section)
    if [ -f "$dir/context.md" ] && grep -q "^## Overview" "$dir/context.md" 2>/dev/null; then
        faint "  ⊘ $name — already migrated"
        return
    fi

    msg "  → Migrating $name"

    # Build context.md from Notes.md, Context Map.md, STATUS.md
    local ctx=""
    ctx+="# $name\n\n"

    # Pull overview from Notes.md or STATUS.md
    if [ -f "$dir/Notes.md" ]; then
        ctx+="## Overview\n$(cat "$dir/Notes.md")\n\n"
        mv "$dir/Notes.md" "$dir/Notes.old.md"
    elif [ -f "$dir/STATUS.md" ]; then
        # Extract overview section from STATUS.md
        local overview
        overview=$(sed -n '/^## Overview/,/^## /{ /^## Overview/d; /^## [^O]/d; p; }' "$dir/STATUS.md" 2>/dev/null)
        [ -n "$overview" ] && ctx+="## Overview\n$overview\n\n"
    fi

    ctx+="## Stack\n(Framework, language, versions, hosting)\n\n"
    ctx+="## Key Files\n(Important file paths and what they do)\n\n"

    # Pull decisions from STATUS.md if present
    if [ -f "$dir/STATUS.md" ]; then
        local decisions
        decisions=$(sed -n '/^## Key Decisions/,/^## /{ /^## /d; p; }' "$dir/STATUS.md" 2>/dev/null)
        if [ -n "$decisions" ] && ! echo "$decisions" | grep -q "^(Record"; then
            ctx+="## Decisions\n$decisions\n\n"
        else
            ctx+="## Decisions\n\n"
        fi
    else
        ctx+="## Decisions\n\n"
    fi

    ctx+="## Gotchas\n\n"

    # Merge Context Map.md content if present
    if [ -f "$dir/Context Map.md" ]; then
        ctx+="\n## Context Map\n$(cat "$dir/Context Map.md")\n"
        mv "$dir/Context Map.md" "$dir/Context Map.old.md"
    fi

    # Merge existing context.md content if it has useful stuff
    if [ -f "$dir/context.md" ]; then
        local existing
        existing=$(cat "$dir/context.md")
        if ! echo "$existing" | grep -q "^(Framework, language"; then
            ctx+="\n---\n## Previous Context\n$existing\n"
        fi
        mv "$dir/context.md" "$dir/context.old.md"
    fi

    printf '%b' "$ctx" > "$dir/context.md"

    # Remove STATUS.md (content absorbed into context.md)
    [ -f "$dir/STATUS.md" ] && mv "$dir/STATUS.md" "$dir/STATUS.old.md"

    # Todos.md → plan.md
    if [ -f "$dir/Todos.md" ]; then
        local todos_content=$(cat "$dir/Todos.md")
        if grep -q '^## ' "$dir/Todos.md"; then
            cat > "$dir/plan.md" << EOF
# Plan

$todos_content
EOF
        else
            cat > "$dir/plan.md" << EOF
# Plan

## Now
$todos_content

## Next

## Later

## Done
EOF
        fi
        mv "$dir/Todos.md" "$dir/Todos.old.md"
    fi

    # Changelog.md + Last Session.md → log.md
    local log_content=""
    if [ -f "$dir/Changelog.md" ]; then
        log_content=$(cat "$dir/Changelog.md")
        mv "$dir/Changelog.md" "$dir/Changelog.old.md"
    fi
    if [ -f "$dir/Last Session.md" ]; then
        local session_content=$(cat "$dir/Last Session.md")
        log_content="## Last Session
$session_content

$log_content"
        mv "$dir/Last Session.md" "$dir/Last Session.old.md"
    fi
    if [ -n "$log_content" ]; then
        cat > "$dir/log.md" << EOF
# Log

$log_content
EOF
    fi

    success "  ✓ $name migrated"
}

knap_hooks_active() {
    local settings_file="$HOME/.claude/settings.json"
    [ -f "$settings_file" ] || return 1
    local count
    count=$(jq -r '.hooks.UserPromptSubmit // [] | map(select(.hooks[]?.command | strings | test("knap"))) | length' "$settings_file" 2>/dev/null || echo "0")
    [ "$count" -gt 0 ]
}

cmd_enable() {
    local CLAUDE_DIR="$HOME/.claude"
    local SETTINGS_FILE="$CLAUDE_DIR/settings.json"
    local BACKUP_FILE="$CLAUDE_DIR/knap-hooks-backup.json"
    local CLAUDE_MD="$CLAUDE_DIR/CLAUDE.md"
    local CODEX_DIR="$HOME/.codex"
    local AGENTS_MD="$CODEX_DIR/AGENTS.md"
    local CONVENTIONS_BACKUP="$CLAUDE_DIR/knap-conventions-backup.md"

    if [ ! -f "$SETTINGS_FILE" ]; then
        warn "No Claude Code settings found at $SETTINGS_FILE"
        exit 1
    fi

    local changed=false

    # Restore hooks
    if ! knap_hooks_active; then
        if [ -f "$BACKUP_FILE" ]; then
            local backup_hooks
            backup_hooks=$(cat "$BACKUP_FILE")

            jq --argjson backup "$backup_hooks" '
                .hooks = ($backup.hooks + (.hooks // {})) |
                .hooks.UserPromptSubmit = ([$backup.hooks.UserPromptSubmit // [], .hooks.UserPromptSubmit // []] | add | unique_by(.hooks[0].command)) |
                .hooks.PostToolUse = ([$backup.hooks.PostToolUse // [], .hooks.PostToolUse // []] | add | unique_by(.hooks[0].command)) |
                .hooks.Stop = ([$backup.hooks.Stop // [], .hooks.Stop // []] | add | unique_by(.hooks[0].command))
            ' "$SETTINGS_FILE" > "$SETTINGS_FILE.tmp" && mv "$SETTINGS_FILE.tmp" "$SETTINGS_FILE"
            rm -f "$BACKUP_FILE"

            faint "  Hooks restored"
            changed=true
        else
            warn "No hook backup found. Run 'knap update' to reinstall hooks."
        fi
    fi

    # Restore conventions in CLAUDE.md / AGENTS.md
    if [ -f "$CONVENTIONS_BACKUP" ]; then
        local conventions
        conventions=$(cat "$CONVENTIONS_BACKUP")

        for md_file in "$CLAUDE_MD" "$AGENTS_MD"; do
            if [ -f "$md_file" ] && ! grep -q "# Knap Conventions" "$md_file" 2>/dev/null; then
                printf "
%s" "$conventions" >> "$md_file"
                faint "  Conventions restored in $(basename "$md_file")"
            fi
        done
        rm -f "$CONVENTIONS_BACKUP"
        changed=true
    fi

    if [ "$changed" = true ]; then
        success "✓ Knap enabled"
    else
        faint "Knap is already enabled"
    fi
}

cmd_disable() {
    local CLAUDE_DIR="$HOME/.claude"
    local SETTINGS_FILE="$CLAUDE_DIR/settings.json"
    local BACKUP_FILE="$CLAUDE_DIR/knap-hooks-backup.json"
    local CLAUDE_MD="$CLAUDE_DIR/CLAUDE.md"
    local CODEX_DIR="$HOME/.codex"
    local AGENTS_MD="$CODEX_DIR/AGENTS.md"
    local CONVENTIONS_BACKUP="$CLAUDE_DIR/knap-conventions-backup.md"

    if [ ! -f "$SETTINGS_FILE" ]; then
        warn "No Claude Code settings found at $SETTINGS_FILE"
        exit 1
    fi

    local changed=false

    # Disable hooks
    if knap_hooks_active; then
        jq '{hooks: .hooks}' "$SETTINGS_FILE" > "$BACKUP_FILE"

        jq '
            .hooks.UserPromptSubmit = ([.hooks.UserPromptSubmit // [] | .[] | select(.hooks | all(.command | test("knap") | not))]) |
            .hooks.PostToolUse = ([.hooks.PostToolUse // [] | .[] | select(.hooks | all(.command | test("knap") | not))]) |
            .hooks.Stop = ([.hooks.Stop // [] | .[] | select(.hooks | all(.command | test("knap") | not))]) |
            if .hooks.UserPromptSubmit == [] then del(.hooks.UserPromptSubmit) else . end |
            if .hooks.PostToolUse == [] then del(.hooks.PostToolUse) else . end |
            if .hooks.Stop == [] then del(.hooks.Stop) else . end |
            if .hooks == {} then del(.hooks) else . end
        ' "$SETTINGS_FILE" > "$SETTINGS_FILE.tmp" && mv "$SETTINGS_FILE.tmp" "$SETTINGS_FILE"

        faint "  Hooks removed"
        changed=true
    fi

    # Remove conventions from CLAUDE.md / AGENTS.md
    for md_file in "$CLAUDE_MD" "$AGENTS_MD"; do
        if [ -f "$md_file" ] && grep -q "# Knap Conventions" "$md_file" 2>/dev/null; then
            # Back up the conventions block (first time only)
            if [ ! -f "$CONVENTIONS_BACKUP" ]; then
                sed -n '/^# Knap Conventions$/,$p' "$md_file" > "$CONVENTIONS_BACKUP"
            fi

            # Remove everything from "# Knap Conventions" to end of file
            sed '/^# Knap Conventions$/,$d' "$md_file" > "${md_file}.tmp" && mv "${md_file}.tmp" "$md_file"

            faint "  Conventions removed from $(basename "$md_file")"
            changed=true
        fi
    done

    if [ "$changed" = true ]; then
        success "✓ Knap disabled"
        faint "Run 'knap enable' to re-enable"
    else
        faint "Knap is already disabled"
    fi
}

# --- Project Resolution ---
# Resolves project name + vault dir from cwd (or explicit name).
# Sets: RESOLVED_PROJECT_NAME, RESOLVED_PROJECT_DIR
# Returns 1 if resolution fails.

resolve_project() {
    local explicit_name="$1"
    RESOLVED_PROJECT_NAME=""
    RESOLVED_PROJECT_DIR=""

    if [ -n "$explicit_name" ]; then
        RESOLVED_PROJECT_NAME="$explicit_name"
        RESOLVED_PROJECT_DIR="$VAULT_DIR/Projects/$explicit_name"
        if [ ! -d "$RESOLVED_PROJECT_DIR" ]; then
            warn "Project '$explicit_name' not found in vault"
            return 1
        fi
        return 0
    fi

    # Resolve from cwd
    local cwd
    cwd="$(pwd)"
    local SEARCH_DIRS=("$HOME/Sites" "$HOME/Projects" "$HOME/Code" "$HOME/Developer" "$HOME/repos" "$HOME/src" "$HOME/workspace")

    for base in "${SEARCH_DIRS[@]}"; do
        if [[ "$cwd" == "$base/"* ]]; then
            local rel="${cwd#$base/}"
            local folder="${rel%%/*}"
            RESOLVED_PROJECT_NAME=$(echo "$folder" | sed -E 's/(^|[-_])([a-z])/\U\2/g; s/[-_]/ /g')
            break
        fi
    done

    # Fallback to git root
    if [ -z "$RESOLVED_PROJECT_NAME" ]; then
        local project_root
        project_root=$(git rev-parse --show-toplevel 2>/dev/null) || true
        if [ -z "$project_root" ]; then
            warn "Could not resolve project from $(pwd)"
            warn "Run from a project directory or pass the project name: knap <cmd> <project>"
            return 1
        fi
        RESOLVED_PROJECT_NAME=$(basename "$project_root" | sed -E 's/(^|[-_])([a-z])/\U\2/g; s/[-_]/ /g')
    fi

    RESOLVED_PROJECT_DIR="$VAULT_DIR/Projects/$RESOLVED_PROJECT_NAME"

    if [ ! -d "$RESOLVED_PROJECT_DIR" ]; then
        warn "Project '$RESOLVED_PROJECT_NAME' not found in vault"
        faint "Run 'knap init' to scaffold it first"
        return 1
    fi

    return 0
}

# --- User-Driven Commands ---

cmd_todo() {
    local section="Now"
    local text=""

    # Parse flags
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --next)   section="Next"; shift ;;
            --later)  section="Later"; shift ;;
            --now)    section="Now"; shift ;;
            -p)       shift; resolve_project "$1" || return; shift ;;
            *)        text="$text $1"; shift ;;
        esac
    done
    text="${text# }"  # trim leading space

    # Resolve project if not set by -p flag
    if [ -z "$RESOLVED_PROJECT_DIR" ]; then
        resolve_project "" || return
    fi

    # Prompt if no text given
    if [ -z "$text" ]; then
        if command -v gum &>/dev/null; then
            text=$(gum input --placeholder "What needs doing?") || return
        else
            read -rp "Todo: " text
        fi
    fi

    [ -z "$text" ] && return

    local plan_file="$RESOLVED_PROJECT_DIR/plan.md"

    # Create plan.md if missing
    if [ ! -f "$plan_file" ]; then
        cat > "$plan_file" << 'EOF'
# Plan

## Now (Active Sprint / Current Focus)

## Next (Queued, not started)

## Later (Backlog, low priority)

## Done (Recently Completed)
EOF
    fi

    # Find the section header and insert after it
    local section_pattern
    case "$section" in
        Now)   section_pattern="^## Now" ;;
        Next)  section_pattern="^## Next" ;;
        Later) section_pattern="^## Later" ;;
    esac

    # Insert the todo after the section header line
    local tmp=$(mktemp)
    local inserted=false
    while IFS= read -r line; do
        echo "$line" >> "$tmp"
        if [ "$inserted" = false ] && [[ "$line" =~ $section_pattern ]]; then
            echo "- [ ] $text" >> "$tmp"
            inserted=true
        fi
    done < "$plan_file"

    if [ "$inserted" = true ]; then
        mv "$tmp" "$plan_file"
        success "✓ Added to $section: $text"
        faint "  $RESOLVED_PROJECT_NAME/plan.md"
    else
        rm -f "$tmp"
        # Section not found — append under Now
        echo "- [ ] $text" >> "$plan_file"
        success "✓ Added: $text"
        faint "  $RESOLVED_PROJECT_NAME/plan.md (appended)"
    fi
}

cmd_done() {
    local explicit_project=""

    # Parse flags
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -p) shift; explicit_project="$1"; shift ;;
            *)  shift ;;
        esac
    done

    resolve_project "$explicit_project" || return

    local plan_file="$RESOLVED_PROJECT_DIR/plan.md"
    if [ ! -f "$plan_file" ]; then
        warn "No plan.md found for $RESOLVED_PROJECT_NAME"
        return
    fi

    # Collect open todos
    local -a todos=()
    local -a line_numbers=()
    local line_num=0
    while IFS= read -r line; do
        line_num=$((line_num + 1))
        if [[ "$line" =~ ^[[:space:]]*-[[:space:]]\[[[:space:]]\][[:space:]](.+)$ ]]; then
            todos+=("${BASH_REMATCH[1]}")
            line_numbers+=("$line_num")
        fi
    done < "$plan_file"

    if [ ${#todos[@]} -eq 0 ]; then
        faint "No open todos in $RESOLVED_PROJECT_NAME"
        return
    fi

    # Let user pick which ones are done
    local selected
    if command -v gum &>/dev/null; then
        selected=$(printf '%s\n' "${todos[@]}" | gum choose --no-limit --header "Mark as done:") || return
    else
        echo "Open todos:"
        local i=1
        for todo in "${todos[@]}"; do
            echo "  $i) $todo"
            i=$((i + 1))
        done
        read -rp "Enter numbers to complete (comma-separated): " nums
        selected=""
        IFS=',' read -ra indices <<< "$nums"
        for idx in "${indices[@]}"; do
            idx=$(echo "$idx" | tr -d ' ')
            if [ "$idx" -ge 1 ] && [ "$idx" -le ${#todos[@]} ] 2>/dev/null; then
                [ -n "$selected" ] && selected+=$'\n'
                selected+="${todos[$((idx - 1))]}"
            fi
        done
    fi

    [ -z "$selected" ] && return

    local today=$(date +%Y-%m-%d)
    local completed_count=0

    # Process each selected todo
    while IFS= read -r done_item; do
        [ -z "$done_item" ] && continue

        # Mark as done in place (checkbox)
        local escaped
        escaped=$(printf '%s\n' "$done_item" | sed 's/[[\.*^$()+?{|]/\\&/g')
        sed -i'' -e "s/- \[ \] ${escaped}/- [x] ${done_item}/" "$plan_file"

        completed_count=$((completed_count + 1))
    done <<< "$selected"

    if [ $completed_count -gt 0 ]; then
        success "✓ Completed $completed_count todo(s) in $RESOLVED_PROJECT_NAME"
    fi
}

cmd_log() {
    local text=""
    local explicit_project=""

    # Parse flags
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -p) shift; explicit_project="$1"; shift ;;
            *)  text="$text $1"; shift ;;
        esac
    done
    text="${text# }"

    resolve_project "$explicit_project" || return

    # Prompt if no text given
    if [ -z "$text" ]; then
        if command -v gum &>/dev/null; then
            text=$(gum input --placeholder "What happened?") || return
        else
            read -rp "Log entry: " text
        fi
    fi

    [ -z "$text" ] && return

    local log_file="$RESOLVED_PROJECT_DIR/log.md"
    local today=$(date +%Y-%m-%d)

    # Create log.md if missing
    if [ ! -f "$log_file" ]; then
        cat > "$log_file" << EOF
# Log

## $today
- $text
EOF
        success "✓ Logged: $text"
        faint "  $RESOLVED_PROJECT_NAME/log.md"
        return
    fi

    # Check if today's date section exists
    if grep -q "^## $today" "$log_file"; then
        # Append under today's section (after the ## date line)
        local tmp=$(mktemp)
        local inserted=false
        while IFS= read -r line; do
            echo "$line" >> "$tmp"
            if [ "$inserted" = false ] && [[ "$line" == "## $today"* ]]; then
                echo "- $text" >> "$tmp"
                inserted=true
            fi
        done < "$log_file"
        mv "$tmp" "$log_file"
    else
        # Insert new date section after "# Log" header
        local tmp=$(mktemp)
        local inserted=false
        while IFS= read -r line; do
            echo "$line" >> "$tmp"
            if [ "$inserted" = false ] && [[ "$line" == "# Log"* ]]; then
                echo "" >> "$tmp"
                echo "## $today" >> "$tmp"
                echo "- $text" >> "$tmp"
                inserted=true
            fi
        done < "$log_file"
        if [ "$inserted" = true ]; then
            mv "$tmp" "$log_file"
        else
            # Fallback: prepend
            rm -f "$tmp"
            local existing
            existing=$(cat "$log_file")
            cat > "$log_file" << EOF
# Log

## $today
- $text

$existing
EOF
        fi
    fi

    success "✓ Logged: $text"
    faint "  $RESOLVED_PROJECT_NAME/log.md"
}

cmd_note() {
    local text=""
    local explicit_project=""
    local section="Decisions"

    # Parse flags
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -p)       shift; explicit_project="$1"; shift ;;
            --gotcha) section="Gotchas"; shift ;;
            *)        text="$text $1"; shift ;;
        esac
    done
    text="${text# }"

    resolve_project "$explicit_project" || return

    # Prompt if no text given
    if [ -z "$text" ]; then
        if command -v gum &>/dev/null; then
            text=$(gum write --placeholder "Note (Ctrl+D to save)...") || return
        else
            read -rp "Note: " text
        fi
    fi

    [ -z "$text" ] && return

    local context_file="$RESOLVED_PROJECT_DIR/context.md"

    if [ ! -f "$context_file" ]; then
        warn "No context.md found for $RESOLVED_PROJECT_NAME"
        return
    fi

    # Append under the target section, or at end of file
    if grep -q "^## $section" "$context_file"; then
        local tmp=$(mktemp)
        local inserted=false
        while IFS= read -r line; do
            echo "$line" >> "$tmp"
            if [ "$inserted" = false ] && [[ "$line" == "## $section"* ]]; then
                echo "- $text" >> "$tmp"
                inserted=true
            fi
        done < "$context_file"
        mv "$tmp" "$context_file"
    else
        echo "" >> "$context_file"
        echo "## $section" >> "$context_file"
        echo "- $text" >> "$context_file"
    fi

    success "✓ Noted in $section: $text"
    faint "  $RESOLVED_PROJECT_NAME/context.md"
}

cmd_review() {
    local explicit_project=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -p) shift; explicit_project="$1"; shift ;;
            *)  shift ;;
        esac
    done

    resolve_project "$explicit_project" || return

    local plan_file="$RESOLVED_PROJECT_DIR/plan.md"
    local log_file="$RESOLVED_PROJECT_DIR/log.md"
    local today=$(date +%Y-%m-%d)

    msg "Reviewing $RESOLVED_PROJECT_NAME"
    echo ""

    # --- Step 1: Show open todos, mark completed ones ---
    if [ -f "$plan_file" ]; then
        local -a todos=()
        while IFS= read -r line; do
            if [[ "$line" =~ ^[[:space:]]*-[[:space:]]\[[[:space:]]\][[:space:]](.+)$ ]]; then
                todos+=("${BASH_REMATCH[1]}")
            fi
        done < "$plan_file"

        if [ ${#todos[@]} -gt 0 ]; then
            echo ""
            msg "Open todos (${#todos[@]}):"

            local selected=""
            if command -v gum &>/dev/null; then
                selected=$(printf '%s\n' "${todos[@]}" | gum choose --no-limit --header "What got done this session?") || true
            else
                local i=1
                for todo in "${todos[@]}"; do
                    echo "  $i) $todo"
                    i=$((i + 1))
                done
                read -rp "Completed (comma-separated numbers, or Enter to skip): " nums
                if [ -n "$nums" ]; then
                    IFS=',' read -ra indices <<< "$nums"
                    for idx in "${indices[@]}"; do
                        idx=$(echo "$idx" | tr -d ' ')
                        if [ "$idx" -ge 1 ] && [ "$idx" -le ${#todos[@]} ] 2>/dev/null; then
                            [ -n "$selected" ] && selected+=$'\n'
                            selected+="${todos[$((idx - 1))]}"
                        fi
                    done
                fi
            fi

            if [ -n "$selected" ]; then
                local completed_items=()
                while IFS= read -r done_item; do
                    [ -z "$done_item" ] && continue
                    local escaped
                    escaped=$(printf '%s\n' "$done_item" | sed 's/[[\.*^$()+?{|]/\\&/g')
                    sed -i'' -e "s/- \[ \] ${escaped}/- [x] ${done_item}/" "$plan_file"
                    completed_items+=("$done_item")
                done <<< "$selected"

                if [ ${#completed_items[@]} -gt 0 ]; then
                    success "  ✓ Marked ${#completed_items[@]} done"
                fi
            fi
        else
            faint "  No open todos"
        fi
    fi

    # --- Step 2: Add new todos ---
    echo ""
    msg "Any new todos? (empty line to finish)"

    local new_todos=()
    while true; do
        local new_todo=""
        if command -v gum &>/dev/null; then
            new_todo=$(gum input --placeholder "New todo (Enter to finish)") || break
        else
            read -rp "  > " new_todo
        fi

        [ -z "$new_todo" ] && break
        new_todos+=("$new_todo")
    done

    if [ ${#new_todos[@]} -gt 0 ] && [ -f "$plan_file" ]; then
        for todo in "${new_todos[@]}"; do
            # Insert under Now section
            local tmp=$(mktemp)
            local inserted=false
            while IFS= read -r line; do
                echo "$line" >> "$tmp"
                if [ "$inserted" = false ] && [[ "$line" =~ ^##[[:space:]]Now ]]; then
                    echo "- [ ] $todo" >> "$tmp"
                    inserted=true
                fi
            done < "$plan_file"
            if [ "$inserted" = true ]; then
                mv "$tmp" "$plan_file"
            else
                rm -f "$tmp"
                echo "- [ ] $todo" >> "$plan_file"
            fi
        done
        success "  ✓ Added ${#new_todos[@]} new todo(s)"
    fi

    # --- Step 3: Log entry ---
    echo ""
    msg "Session summary for the log:"

    local summary=""
    if command -v gum &>/dev/null; then
        summary=$(gum write --placeholder "What happened this session? (Ctrl+D to save)") || true
    else
        read -rp "  Summary: " summary
    fi

    if [ -n "$summary" ]; then
        # Build the log entry
        local log_entry=""
        log_entry+="### What was done\n"
        log_entry+="$summary\n"

        # Include completed items if any
        if [ ${#completed_items[@]} -gt 0 ]; then
            log_entry+="\n### Completed\n"
            for item in "${completed_items[@]}"; do
                log_entry+="- $item\n"
            done
        fi

        # Include new todos if any
        if [ ${#new_todos[@]} -gt 0 ]; then
            log_entry+="\n### Added\n"
            for item in "${new_todos[@]}"; do
                log_entry+="- $item\n"
            done
        fi

        # Write to log.md
        if [ ! -f "$log_file" ]; then
            printf "# Log\n\n## %s\n%b" "$today" "$log_entry" > "$log_file"
        elif grep -q "^## $today" "$log_file"; then
            # Append to existing date section
            local tmp=$(mktemp)
            local inserted=false
            while IFS= read -r line; do
                echo "$line" >> "$tmp"
                if [ "$inserted" = false ] && [[ "$line" == "## $today"* ]]; then
                    printf '%b' "$log_entry" >> "$tmp"
                    inserted=true
                fi
            done < "$log_file"
            mv "$tmp" "$log_file"
        else
            # New date section
            local tmp=$(mktemp)
            local inserted=false
            while IFS= read -r line; do
                echo "$line" >> "$tmp"
                if [ "$inserted" = false ] && [[ "$line" == "# Log"* ]]; then
                    echo "" >> "$tmp"
                    echo "## $today" >> "$tmp"
                    printf '%b' "$log_entry" >> "$tmp"
                    inserted=true
                fi
            done < "$log_file"
            mv "$tmp" "$log_file"
        fi

        success "  ✓ Logged to $RESOLVED_PROJECT_NAME/log.md"
    fi

    echo ""
    success "✓ Review complete for $RESOLVED_PROJECT_NAME"
}

cmd_ship() {
    local explicit_project=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -p) shift; explicit_project="$1"; shift ;;
            *)  shift ;;
        esac
    done

    resolve_project "$explicit_project" || return

    msg "Ship check for $RESOLVED_PROJECT_NAME"
    echo ""

    local plan_file="$RESOLVED_PROJECT_DIR/plan.md"

    # Show remaining open todos as a sanity check
    if [ -f "$plan_file" ]; then
        local open_count
        open_count=$(grep -c '^\- \[ \]' "$plan_file" 2>/dev/null || true)
        open_count="${open_count:-0}"

        if [ "$open_count" -gt 0 ]; then
            warn "  ⚠ $open_count open todo(s) remaining"
            echo ""
            grep '^\- \[ \]' "$plan_file" | while IFS= read -r line; do
                faint "    $line"
            done
            echo ""

            local proceed=true
            if command -v gum &>/dev/null; then
                gum confirm "Continue with review before shipping?" || proceed=false
            else
                read -rp "Continue with review before shipping? [Y/n] " -n 1 -r
                echo ""
                [[ "$REPLY" =~ ^[Nn]$ ]] && proceed=false
            fi

            [ "$proceed" = false ] && return
        else
            success "  ✓ All todos complete"
        fi
    fi

    # Run review
    echo ""
    cmd_review ${explicit_project:+-p "$explicit_project"}

    # Sync vault
    echo ""
    cmd_sync

    echo ""
    success "✓ Ready to ship $RESOLVED_PROJECT_NAME"
}

cmd_open() {
    local explicit_project=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -p) shift; explicit_project="$1"; shift ;;
            *)  shift ;;
        esac
    done

    resolve_project "$explicit_project" || return

    if command -v open &>/dev/null; then
        open "$RESOLVED_PROJECT_DIR"
        faint "Opened $RESOLVED_PROJECT_NAME in Finder"
    elif command -v xdg-open &>/dev/null; then
        xdg-open "$RESOLVED_PROJECT_DIR"
        faint "Opened $RESOLVED_PROJECT_NAME"
    else
        echo "$RESOLVED_PROJECT_DIR"
    fi
}

cmd_help() {
    echo ""
    msg "knap — manage the Knap vault"
    echo ""
    echo "  Project Management:"
    echo "    knap init             Scaffold project from cwd (detects stack, git log, TODOs)"
    echo "    knap project <name>   Scaffold a new empty project"
    echo "    knap populate         Scan local dirs and scaffold new projects"
    echo "    knap projects         List all projects"
    echo ""
    echo "  Day-to-Day:"
    echo "    knap todo \"text\"      Add a TODO to plan.md (--next, --later for other sections)"
    echo "    knap done             Interactively mark TODOs as complete"
    echo "    knap log \"text\"       Add a changelog entry under today's date"
    echo "    knap note \"text\"      Add a note to STATUS.md"
    echo ""
    echo "  Session Flow:"
    echo "    knap review           End-of-session review (mark done, add todos, write log)"
    echo "    knap ship             Pre-deploy: review + sync"
    echo ""
    echo "  Vault:"
    echo "    knap sync             Commit & push vault changes"
    echo "    knap tidy             Bring project up to current convention (--all for all)"
    echo "    knap open             Open project vault dir in Finder"
    echo "    knap status           Show vault info"
    echo "    knap migrate [name]   Legacy migration (old format → new)"
    echo ""
    echo "  Config:"
    echo "    knap enable           Enable knap hooks in Claude Code"
    echo "    knap disable          Disable knap hooks in Claude Code"
    echo "    knap update           Pull latest hooks, skills & CLI"
    echo "    knap version          Show version"
    echo ""
    echo "  Most commands auto-detect the project from your cwd."
    echo "  Use -p <name> to target a specific project."
    echo ""
}

cmd_version() {
    echo "knap $KNAP_VERSION"
}

# --- Dispatch ---

case "${1:-}" in
    init)     cmd_init ;;
    project)  cmd_project "$2" ;;
    populate) cmd_populate ;;
    projects) cmd_projects ;;
    todo)     shift; cmd_todo "$@" ;;
    done)     shift; cmd_done "$@" ;;
    log)      shift; cmd_log "$@" ;;
    note)     shift; cmd_note "$@" ;;
    review)   shift; cmd_review "$@" ;;
    ship)     shift; cmd_ship "$@" ;;
    open)     shift; cmd_open "$@" ;;
    tidy)     shift; cmd_tidy "$@" ;;
    migrate)  cmd_migrate "$2" ;;
    sync)     cmd_sync ;;
    update)   cmd_update ;;
    status)   cmd_status ;;
    enable)   cmd_enable ;;
    disable)  cmd_disable ;;
    version|-v|--version)  cmd_version ;;
    help)     cmd_help ;;
    *)        cmd_help ;;
esac
